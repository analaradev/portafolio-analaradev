---
// Contact.astro – Contact section & site footer
---

<section id="contact" class="section">
  <div class="container">
    <h2 class="section-title"><span class="gradient-text">Contacto</span></h2>
    <p class="section-subtitle">Hablemos sobre tu próximo proyecto</p>

    <div class="contact-wrapper animate-in">
      <div class="glass-card contact-card">
        <p class="contact-intro">
          Disponible para proyectos de desarrollo de software: aplicaciones móviles, sistemas web, APIs y plataformas administrativas. Trabajo remoto preferente, con disponibilidad híbrida o presencial en Tampico o Ciudad Madero.
        </p>

        <!-- Contact methods grid -->
        <div class="contact-methods">
          <!-- Email -->
          <a href="mailto:analara.stay@gmail.com" class="contact-method" aria-label="Enviar email">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="icon-email">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="M22 4l-10 8L2 4"></path>
            </svg>
            <span class="method-label">Email</span>
            <span class="method-value">analara.stay@gmail.com</span>
          </a>

          <!-- GitHub -->
          <a href="https://github.com/analaradev" target="_blank" rel="noopener noreferrer" class="contact-method" aria-label="Perfil de GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="icon-github">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            <span class="method-label">GitHub</span>
            <span class="method-value">@analaradev</span>
          </a>

          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/in/analaradev" target="_blank" rel="noopener noreferrer" class="contact-method" aria-label="Perfil de LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="icon-linkedin">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span class="method-label">LinkedIn</span>
            <span class="method-value">analaradev</span>
          </a>

          <!-- Instagram -->
          <a href="https://www.instagram.com/analaradev" target="_blank" rel="noopener noreferrer" class="contact-method" aria-label="Perfil de Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="icon-instagram">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
            <span class="method-label">Instagram</span>
            <span class="method-value">@analaradev</span>
          </a>
        </div>

        <!-- CTA Button -->
        <a href="mailto:analara.stay@gmail.com" class="btn-primary cta-btn">
          Envíame un correo
        </a>
      </div>

      <!-- Footer -->
      <footer class="site-footer">
        <div class="footer-divider"></div>
        <p class="footer-copy">
          © 2026 Ana Patricia Hernández Lara. Hecho con <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="astro-link">Astro</a>
        </p>
        <div class="footer-socials">
          <a href="https://github.com/analaradev" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/analaradev" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/analaradev" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="mailto:analara.stay@gmail.com" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="M22 4l-10 8L2 4"></path>
            </svg>
          </a>
        </div>
      </footer>
    </div>
  </div>
</section>

<style>
  /* ───────────────────────────────────────────
     Contact Section
     ─────────────────────────────────────────── */

  .contact-wrapper {
    max-width: 100%;
    margin: 0 auto;
  }

  /* ── Main Glass Card ────────────────────── */
  .contact-card {
    padding: 3rem;
    text-align: center;
  }

  .contact-card:hover {
    transform: none;
  }

  /* ── Intro Paragraph ────────────────────── */
  .contact-intro {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto 2.5rem;
  }

  /* ── Contact Methods Grid ───────────────── */
  .contact-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .contact-method {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    padding: 1.5rem;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    border-radius: var(--border-radius);
    text-decoration: none;
    text-align: center;
    transition: var(--transition);
    cursor: pointer;
  }

  .contact-method:hover {
    transform: scale(1.05);
    box-shadow: var(--shadow-glow);
    background: var(--bg-card-hover);
    border-color: rgba(96, 114, 90, 0.25);
  }

  /* ── Contact Icons ──────────────────────── */
  .icon-email {
    color: var(--accent-primary);
  }

  .icon-github {
    color: var(--text-primary);
  }

  .icon-linkedin {
    color: #0077B5;
  }

  .icon-instagram {
    color: #E1306C;
  }

  .icon-certificate {
    color: var(--accent-primary);
  }

  /* ── Method Labels & Values ─────────────── */
  .method-label {
    font-weight: 600;
    font-size: 1rem;
    color: var(--text-primary);
  }

  .method-value {
    color: var(--text-secondary);
    font-size: 0.9rem;
    word-break: break-all;
  }

  /* ── CTA Button ─────────────────────────── */
  .cta-btn {
    display: flex;
    width: fit-content;
    margin: 2rem auto 0;
  }

  /* ── Footer ─────────────────────────────── */
  .site-footer {
    padding-top: 3rem;
    text-align: center;
  }

  .footer-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--glass-border),
      rgba(96, 114, 90, 0.2),
      var(--glass-border),
      transparent
    );
    margin-bottom: 1.5rem;
  }

  .footer-copy {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .astro-link {
    color: var(--accent-secondary);
    font-weight: 500;
    transition: var(--transition);
  }

  .astro-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Footer Social Icons ────────────────── */
  .footer-socials {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  .footer-socials a {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    transition: var(--transition);
  }

  .footer-socials a svg {
    width: 20px;
    height: 20px;
  }

  .footer-socials a:hover {
    color: var(--accent-primary);
    transform: translateY(-2px);
  }

  /* ─────────────────────────────────────────
     Responsive
     ───────────────────────────────────────── */

  /* Tablet & mobile */
  @media (max-width: 768px) {
    .contact-methods {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .contact-card {
      padding: 2rem 1.5rem;
    }

    .contact-intro {
      font-size: 1rem;
      margin-bottom: 2rem;
    }
  }

  /* Small mobile */
  @media (max-width: 480px) {
    .contact-card {
      padding: 1.5rem 1.25rem;
    }

    .contact-intro {
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .contact-method {
      padding: 1.25rem 1rem;
    }

    .method-value {
      font-size: 0.85rem;
    }
  }
</style>
