---
// Navbar.astro — Premium sticky navigation with glassmorphism & mobile menu
const navLinks = [
  { label: 'Sobre mí', href: '/#about' },
  { label: 'Experiencia', href: '/#experience' },
  { label: 'Proyectos', href: '/#projects' },
  { label: 'Tech Stack', href: '/#techstack' },
  { label: 'Certificaciones', href: '/#certifications' },
  { label: 'Certificados', href: '/certificados' },
  { label: 'Contacto', href: '/#contact' },
];
---

<header class="navbar" id="navbar">
  <div class="navbar__container">
    <!-- Desktop & Mobile Navigation -->
    <nav class="navbar__nav" id="navMenu" aria-label="Navegación principal">
      <ul class="navbar__links">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="navbar__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Hamburger Button -->
    <button
      class="navbar__hamburger"
      id="hamburgerBtn"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="navMenu"
    >
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
    </button>
  </div>
</header>

<!-- Overlay for mobile menu -->
<div class="navbar__overlay" id="navOverlay"></div>

<style>
  /* ── Navbar Shell ─────────────────────────────────── */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--glass-border, rgba(255, 255, 255, 0.08));
    padding: 1rem 2rem;
    transition: background 0.35s ease, box-shadow 0.35s ease, padding 0.35s ease;
  }

  .navbar.scrolled {
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 4px 30px rgba(96, 114, 90, 0.05);
    padding: 0.7rem 2rem;
  }

  /* ── Container ────────────────────────────────────── */
  .navbar__container {
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Navigation Links ─────────────────────────────── */
  .navbar__links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    border: 1px solid transparent;
    transition: all 0.35s cubic-bezier(0.25, 1, 0.5, 1);
    display: inline-block;
  }

  .navbar__link:hover,
  .navbar__link.active {
    color: var(--accent-primary);
    background: rgba(96, 114, 90, 0.07);
    border-color: rgba(96, 114, 90, 0.15);
    transform: translateY(-1px);
  }

  /* ── Hamburger Button ─────────────────────────────── */
  .navbar__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid var(--glass-border, rgba(255, 255, 255, 0.08));
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, border-color 0.3s ease;
    z-index: 1002;
  }

  .navbar__hamburger:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--accent-primary);
  }

  .navbar__hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: transform 0.35s ease, opacity 0.25s ease, background 0.3s ease;
  }

  /* Hamburger → X animation */
  .navbar__hamburger.open .navbar__hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background: var(--accent-primary);
  }

  .navbar__hamburger.open .navbar__hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .navbar__hamburger.open .navbar__hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    background: var(--accent-primary);
  }

  /* ── Overlay ──────────────────────────────────────── */
  .navbar__overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease, visibility 0.35s ease;
  }

  .navbar__overlay.visible {
    opacity: 1;
    visibility: visible;
  }

  /* ── Mobile Styles ────────────────────────────────── */
  @media (max-width: 768px) {
    .navbar {
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border-bottom: none;
      box-shadow: none;
      padding: 0.85rem 1.25rem;
    }

    .navbar.scrolled {
      background: transparent;
      box-shadow: none;
      padding: 0.85rem 1.25rem;
    }

    .navbar__container {
      justify-content: flex-end;
    }

    .navbar__hamburger {
      display: flex;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border, rgba(96, 114, 90, 0.15));
      box-shadow: 0 4px 15px rgba(96, 114, 90, 0.08);
    }

    .navbar__hamburger:hover {
      background: rgba(255, 255, 255, 0.95);
      border-color: var(--accent-primary);
    }

    .navbar__nav {
      position: fixed;
      top: 0;
      right: 0;
      width: min(320px, 80vw);
      height: 100vh;
      height: 100dvh;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-left: 1px solid var(--glass-border, rgba(96, 114, 90, 0.15));
      z-index: 999;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: -8px 0 40px rgba(96, 114, 90, 0.05);
    }

    .navbar__nav.open {
      transform: translateX(0);
    }

    .navbar__links {
      flex-direction: column;
      gap: 0;
      width: 100%;
      padding: 2rem 1.5rem;
    }

    .navbar__links li {
      width: 100%;
      opacity: 0;
      transform: translateX(20px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .navbar__nav.open .navbar__links li {
      opacity: 1;
      transform: translateX(0);
    }

    /* Stagger the link animations */
    .navbar__nav.open .navbar__links li:nth-child(1) { transition-delay: 0.08s; }
    .navbar__nav.open .navbar__links li:nth-child(2) { transition-delay: 0.14s; }
    .navbar__nav.open .navbar__links li:nth-child(3) { transition-delay: 0.20s; }
    .navbar__nav.open .navbar__links li:nth-child(4) { transition-delay: 0.26s; }
    .navbar__nav.open .navbar__links li:nth-child(5) { transition-delay: 0.32s; }
    .navbar__nav.open .navbar__links li:nth-child(6) { transition-delay: 0.38s; }
    .navbar__nav.open .navbar__links li:nth-child(7) { transition-delay: 0.44s; }

    .navbar__link {
      display: block;
      padding: 0.8rem 1.2rem;
      font-size: 1.05rem;
      border-radius: 12px;
      margin: 0.25rem 0;
      border: 1px solid transparent;
      transition: all 0.3s ease;
    }

    .navbar__link:hover,
    .navbar__link.active {
      color: var(--accent-primary);
      background: rgba(96, 114, 90, 0.08);
      border-color: rgba(96, 114, 90, 0.15);
      transform: translateX(4px);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navbar = document.getElementById('navbar');
    const navMenu = document.getElementById('navMenu');
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const navOverlay = document.getElementById('navOverlay');
    const navLinks = document.querySelectorAll('.navbar__link');

    if (!navbar || !navMenu || !hamburgerBtn || !navOverlay) return;

    // ── Toggle mobile menu ──────────────────────────
    function openMenu() {
      navMenu.classList.add('open');
      hamburgerBtn.classList.add('open');
      hamburgerBtn.setAttribute('aria-expanded', 'true');
      navOverlay.classList.add('visible');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      navMenu.classList.remove('open');
      hamburgerBtn.classList.remove('open');
      hamburgerBtn.setAttribute('aria-expanded', 'false');
      navOverlay.classList.remove('visible');
      document.body.style.overflow = '';
    }

    hamburgerBtn.addEventListener('click', () => {
      const isOpen = navMenu.classList.contains('open');
      isOpen ? closeMenu() : openMenu();
    });

    // Close on overlay click
    navOverlay.addEventListener('click', closeMenu);

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && navMenu.classList.contains('open')) {
        closeMenu();
      }
    });

    // ── Scrolled class ──────────────────────────────
    function handleScroll() {
      if (window.scrollY > 50) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Set initial state

    // ── Link clicks: smooth scroll & close menu ─────
    navLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');

        if (href && (href.startsWith('#') || href.startsWith('/#'))) {
          const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html' || window.location.pathname === '';
          if (isHome) {
            e.preventDefault();
            const hashIndex = href.indexOf('#');
            const hash = href.substring(hashIndex);
            const target = document.querySelector(hash);

            if (target) {
              closeMenu();

              // Small delay so the mobile menu closes before scrolling
              const delay = navMenu.classList.contains('open') ? 350 : 0;
              setTimeout(() => {
                const navbarHeight = navbar.offsetHeight;
                const targetPosition =
                  target.getBoundingClientRect().top + window.scrollY - navbarHeight - 16;

                window.scrollTo({
                  top: targetPosition,
                  behavior: 'smooth',
                });
              }, delay);
            }
          }
        }
      });
    });

    // ── Active link tracking on scroll ──────────────
    const sections = document.querySelectorAll('section[id]');

    function highlightActiveLink() {
      const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html' || window.location.pathname === '';
      if (!isHome) return;

      const scrollPos = window.scrollY + navbar.offsetHeight + 100;

      sections.forEach((section) => {
        const sectionTop = section.offsetTop;
        const sectionHeight = section.offsetHeight;
        const sectionId = section.getAttribute('id');

        if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
          navLinks.forEach((link) => {
            link.classList.remove('active');
            const href = link.getAttribute('href');
            if (href === `#${sectionId}` || href === `/#${sectionId}`) {
              link.classList.add('active');
            }
          });
        }
      });
    }

    window.addEventListener('scroll', highlightActiveLink, { passive: true });
    highlightActiveLink();
  });
</script>
