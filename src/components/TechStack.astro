---
const categories = [
  {
    name: "Mobile Development",
    accent: "#02569B",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    techs: ["Flutter", "Dart", "GetX", "Clean Architecture", "Google Play", "App Store"],
  },
  {
    name: "Frontend Web",
    accent: "#DD0031",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    techs: ["Angular", "Astro", "TypeScript", "JavaScript", "HTML5", "CSS3", "Bootstrap"],
  },
  {
    name: "Backend & APIs",
    accent: "#FF2D20",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
    techs: ["Laravel", "PHP", "CodeIgniter", ".NET Core", "C#", "Node.js", "Express", "APIs REST"],
  },
  {
    name: "Bases de Datos",
    accent: "#4479A1",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
    techs: ["SQL Server", "MySQL", "Firebase"],
  },
  {
    name: "DevOps & Herramientas",
    accent: "#F05032",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    techs: ["Git", "GitHub", "Hostinger", "Postman", "VS Code"],
  },
  {
    name: "IA & Tecnologías Emergentes",
    accent: "#ffa500",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7z"/><path d="M9 21h6"/><path d="M10 17v4"/><path d="M14 17v4"/><line x1="12" y1="7" x2="12" y2="11"/><line x1="10" y1="9" x2="14" y2="9"/></svg>`,
    techs: ["Ollama", "Open WebUI", "RAG", "Modelos Open-Source", "Python", "Unity/VR"],
  },
];
---

<section id="techstack" class="section">
  <div class="container">
    <h2 class="section-title gradient-text">Tech Stack</h2>
    <p class="section-subtitle">Tecnologías que domino y utilizo</p>

    <div class="categories-grid animate-in">
      {categories.map((cat) => (
        <div class="glass-card category-card" style={`--cat-accent: ${cat.accent};`}>
          <div class="category-header">
            <span class="category-icon" set:html={cat.icon} />
            <span class="category-name">{cat.name}</span>
          </div>
          <div class="tech-list">
            {cat.techs.map((tech) => (
              <span class="tech-pill">{tech}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .categories-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .categories-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .category-card {
    background: var(--bg-card);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 1.5rem;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(96, 114, 90, 0.06);
    border-color: rgba(96, 114, 90, 0.25);
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .category-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cat-accent);
    flex-shrink: 0;
  }

  .category-name {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tech-pill {
    background: rgba(255, 255, 255, 0.45);
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
    cursor: default;
  }

  .tech-pill:hover {
    transform: scale(1.08);
    border-color: var(--cat-accent);
    background: rgba(255, 255, 255, 0.8);
    color: var(--text-primary);
  }

  /* animate-in */
  .animate-in {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeSlideIn 0.7s ease forwards;
  }

  @keyframes fadeSlideIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
