---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const certificates = [
  {
    title: 'Critical Career Skills - Generative AI Foundations',
    issuer: 'Certiport / Pearson VUE',
    platform: 'Critical Career Skills',
    issued: 'Mayo 25, 2026',
    credential: 'M4Yz-s4m6',
    category: 'IA generativa',
    preview: '/certificates/previews/generative-ai-foundations.png',
    pdf: '/certificates/generative-ai-foundations.pdf',
    verify: 'https://www.credly.com/badges/3db37b68-547b-4242-a436-72a47493a6b8/public_url',
    summary: 'Fundamentos de IA generativa, aplicaciones prácticas, uso responsable y contexto profesional.',
    highlights: ['Uso responsable de IA', 'Aplicaciones profesionales', 'Fundamentos de IA generativa'],
    tags: ['IA Generativa', 'Certiport', 'Pearson VUE'],
    accentColor: '#60725a',
    featured: true,
  },
  {
    title: 'IT Specialist - Databases',
    issuer: 'Certiport / Pearson VUE',
    platform: 'Information Technology Specialist',
    issued: 'Mayo 25, 2026',
    credential: 'wYS3H-2FvB',
    category: 'Bases de datos',
    preview: '/certificates/previews/databases.png',
    pdf: '/certificates/databases.pdf',
    verify: 'https://www.credly.com/badges/174febca-5b0c-4031-9e85-7aecdc1456b1/public_url',
    summary: 'Certificación en fundamentos de bases de datos relacionales, consulta, diseño y administración.',
    highlights: ['Diseño relacional', 'Consultas SQL', 'Administración de bases de datos'],
    tags: ['Databases', 'SQL', 'ITS'],
    accentColor: '#879b80',
  },
  {
    title: 'IT Specialist - Data Analytics',
    issuer: 'Certiport / Pearson VUE',
    platform: 'Information Technology Specialist',
    issued: 'Mayo 14, 2026',
    credential: 'MnEz-s4bx',
    category: 'Analítica de datos',
    preview: '/certificates/previews/data-analytics.png',
    pdf: '/certificates/data-analytics.pdf',
    verify: 'https://www.credly.com/badges/5fcd49fc-784f-49f7-b172-91a9ec172b46/public_url',
    summary: 'Procesamiento, análisis e interpretación de datos para apoyar decisiones y reportes.',
    highlights: ['Procesamiento de datos', 'Interpretación', 'Reportes y decisiones'],
    tags: ['Analytics', 'Data', 'ITS'],
    accentColor: '#a5b8a0',
  },
  {
    title: 'Google Cybersecurity Professional Certificate',
    issuer: 'Google / Coursera',
    platform: 'Professional Certificate',
    issued: 'Mayo 12, 2026',
    credential: 'SBWWO1MAKA8X',
    category: 'Ciberseguridad',
    preview: '/certificates/previews/google-cybersecurity.png',
    pdf: '/certificates/google-cybersecurity.pdf',
    verify: 'https://coursera.org/share/f02f45c508f15db2b8a6a5e045996080',
    summary: 'Programa profesional de Google con fundamentos de seguridad, redes, Linux, SQL, SIEM, IDS y respuesta a incidentes.',
    highlights: ['Seguridad y redes', 'Linux, SQL y SIEM', 'Respuesta a incidentes'],
    tags: ['Google', 'Cybersecurity', 'Coursera'],
    accentColor: '#6d8569',
  },
  {
    title: 'IT Specialist - Cybersecurity',
    issuer: 'Certiport / Pearson VUE',
    platform: 'Information Technology Specialist',
    issued: 'Mayo 20, 2026',
    credential: 'w9MMq-FarL',
    category: 'Ciberseguridad',
    preview: '/certificates/previews/cybersecurity.png',
    pdf: '/certificates/cybersecurity.pdf',
    verify: 'https://www.credly.com/badges/771efe29-9417-4feb-8110-1587503ee63f/public_url',
    summary: 'Conocimientos sobre amenazas, vulnerabilidades, controles y prácticas de protección de sistemas.',
    highlights: ['Amenazas y vulnerabilidades', 'Controles de seguridad', 'Protección de sistemas'],
    tags: ['Cybersecurity', 'ITS', 'Certiport'],
    accentColor: '#859680',
  },
];
---

<Layout title="Certificados | Ana Patricia Hernández Lara">
  <Navbar />

  <main class="certificates-page">
    <div class="container">
      <div class="back-home-wrapper animate-in visible">
        <a href="/" class="btn-back-home">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Volver al inicio
        </a>
      </div>

      <h1 class="page-title gradient-text animate-in visible">Certificados</h1>
      <p class="page-subtitle animate-in visible">Constancias en PDF y enlaces de verificación de certificaciones en bases de datos, analítica, IA generativa y ciberseguridad.</p>

      <div class="certificates-grid">
        {certificates.map((certificate) => (
          <article
            class={`certificate-card glass-card animate-in visible ${certificate.featured ? 'certificate-card--featured' : ''}`}
            style={`--card-accent: ${certificate.accentColor};`}
          >
            <div class="certificate-card__glow" />

            <div class="certificate-card__content">
              <div class="certificate-card__header">
                <span class="certificate-card__type">{certificate.category}</span>
                {certificate.featured && (
                  <span class="certificate-card__featured-badge">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                    Destacado
                  </span>
                )}
              </div>

              <h2 class="certificate-card__title">{certificate.title}</h2>
              <p class="certificate-card__description">{certificate.summary}</p>

              <ul class="certificate-card__highlights">
                {certificate.highlights.map((highlight) => (
                  <li class="certificate-card__highlight">
                    <svg class="certificate-card__check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    {highlight}
                  </li>
                ))}
              </ul>

              <dl class="certificate-card__meta">
                <div>
                  <dt>Emisor</dt>
                  <dd>{certificate.issuer}</dd>
                </div>
                <div>
                  <dt>Fecha</dt>
                  <dd>{certificate.issued}</dd>
                </div>
                <div>
                  <dt>ID</dt>
                  <dd>{certificate.credential}</dd>
                </div>
              </dl>

              <div class="certificate-card__tags-links">
                <div class="certificate-card__tags">
                  {certificate.tags.map((tag) => (
                    <span class="certificate-card__tag">{tag}</span>
                  ))}
                </div>

                <div class="certificate-card__links">
                  <a href={certificate.pdf} target="_blank" rel="noopener noreferrer" class="certificate-card__link">
                    Ver PDF
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                      <path d="M14 2v6h6" />
                    </svg>
                  </a>
                  <a href={certificate.verify} target="_blank" rel="noopener noreferrer" class="certificate-card__link">
                    Verificar
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      <path d="M15 3h6v6" />
                      <path d="M10 14L21 3" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>

            <a href={certificate.pdf} target="_blank" rel="noopener noreferrer" class="certificate-card__gallery" aria-label={`Abrir PDF de ${certificate.title}`}>
              <div class="certificate-card__gallery-viewport">
                <img src={certificate.preview} alt={`Vista previa del certificado ${certificate.title}`} loading="lazy" />
              </div>
              <div class="certificate-card__gallery-caption">
                <span class="certificate-card__gallery-label">{certificate.platform}</span>
                <span class="certificate-card__gallery-counter">PDF</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .certificates-page {
    padding: 8rem 0 6rem;
    background: linear-gradient(
      180deg,
      var(--bg-primary) 0%,
      var(--bg-secondary) 50%,
      var(--bg-primary) 100%
    );
    min-height: 100vh;
  }

  .back-home-wrapper {
    margin-bottom: 2rem;
  }

  .btn-back-home {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: var(--transition);
  }

  .btn-back-home:hover {
    color: var(--accent-primary);
    transform: translateX(-4px);
  }

  .page-title {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 700px;
    margin-bottom: 3rem;
    line-height: 1.7;
  }

  .certificates-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .certificate-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.4s ease;
  }

  .certificate-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--card-accent), transparent);
    opacity: 0.25;
  }

  .certificate-card__glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, color-mix(in srgb, var(--card-accent) 8%, transparent), transparent 70%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .certificate-card:hover {
    transform: translateY(-6px);
    box-shadow:
      0 20px 40px rgba(96, 114, 90, 0.08),
      0 0 30px color-mix(in srgb, var(--card-accent) 12%, transparent);
    border-color: var(--card-accent);
  }

  .certificate-card:hover .certificate-card__glow {
    opacity: 1;
  }

  .certificate-card:hover .certificate-card__title {
    color: var(--card-accent);
  }

  .certificate-card--featured {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, rgba(96, 114, 90, 0.06) 0%, var(--glass) 100%);
    border-width: 1px;
    box-shadow:
      0 0 50px rgba(96, 114, 90, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  @media (min-width: 900px) {
    .certificate-card--featured {
      display: grid;
      grid-template-columns: 1.25fr 1fr;
      gap: 2.5rem;
      align-items: center;
    }
  }

  .certificate-card__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .certificate-card__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .certificate-card__type,
  .certificate-card__featured-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 50px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .certificate-card__type {
    padding: 0.3rem 0.85rem;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-accent) 25%, transparent);
  }

  .certificate-card__featured-badge {
    gap: 0.35rem;
    padding: 0.3rem 0.75rem;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: #fbbf24;
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.25);
  }

  .certificate-card__title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .certificate-card__description {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .certificate-card__highlights {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0.25rem 0;
  }

  .certificate-card__highlight {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .certificate-card__check {
    flex-shrink: 0;
    color: var(--card-accent);
    opacity: 0.85;
  }

  .certificate-card__meta {
    display: grid;
    gap: 0.45rem;
    margin: 0.2rem 0 0.1rem;
  }

  .certificate-card__meta div {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr);
    gap: 0.55rem;
  }

  .certificate-card__meta dt {
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .certificate-card__meta dd {
    color: var(--text-primary);
    font-size: 0.84rem;
    overflow-wrap: anywhere;
  }

  .certificate-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .certificate-card__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.7rem;
    border-radius: 50px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--glass-border);
    transition: var(--transition);
    white-space: nowrap;
  }

  .certificate-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--glass-border);
    margin-top: 0.75rem;
  }

  .certificate-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--glass-border);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .certificate-card__link:hover {
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--card-accent) 35%, transparent);
    transform: translateY(-1px);
    box-shadow: 0 4px 15px color-mix(in srgb, var(--card-accent) 15%, transparent);
  }

  .certificate-card__gallery {
    position: relative;
    width: 100%;
    border-radius: var(--border-radius-sm);
    border: 1px solid var(--glass-border);
    overflow: hidden;
    background: var(--bg-secondary);
    box-shadow: 0 4px 15px rgba(96, 114, 90, 0.04);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    z-index: 1;
  }

  .certificate-card__gallery-viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-in;
  }

  .certificate-card__gallery-viewport img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.5rem;
    transition: transform 0.35s ease;
  }

  .certificate-card:hover .certificate-card__gallery-viewport img {
    transform: scale(1.02);
  }

  .certificate-card__gallery-caption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.9rem;
    background: rgba(255, 255, 255, 0.45);
    border-top: 1px solid var(--glass-border);
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  .certificate-card__gallery-label {
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 70%;
  }

  .certificate-card__gallery-counter {
    font-family: var(--font-mono);
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .certificates-grid {
      grid-template-columns: 1fr;
    }

    .certificate-card--featured {
      grid-column: span 1;
    }
  }

  @media (max-width: 480px) {
    .certificates-page {
      padding: 6rem 0 4rem;
    }

    .page-title {
      font-size: 2rem;
    }

    .page-subtitle {
      font-size: 1rem;
      margin-bottom: 2rem;
    }

    .certificates-grid {
      gap: 1.5rem;
    }

    .certificate-card__title {
      font-size: 1.15rem;
    }

    .certificate-card__description {
      font-size: 0.9rem;
    }

    .certificate-card__links {
      flex-direction: column;
    }

    .certificate-card__link {
      justify-content: center;
    }

    .certificate-card__meta div {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }

    .certificate-card__gallery-caption {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.2rem;
    }
  }
</style>
