  .project-card__gallery-label {
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 70%;
  }

  .project-card__gallery-counter {
    font-family: var(--font-mono);
    opacity: 0.8;
  }

  .project-card__gallery-controls {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    left: 0.5rem;
    right: 0.5rem;
