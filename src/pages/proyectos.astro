---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

interface ProjectLink {
  label: string;
  url: string;
  icon?: string;
}

interface Project {
  name: string;
  type: string;
  description: string;
  tech: string[];
  links: ProjectLink[];
  highlights: string[];
  metrics?: { value: string; label: string }[];
  featured?: boolean;
  accentColor: string;
  category: 'mobile' | 'web' | 'others';
  screenshots?: { src: string; label: string }[];
}

const projects: Project[] = [
  {
    name: 'Pan de Vida',
    type: 'App Móvil + Sistema + POS',
    description:
      'Proyecto integral: aplicación móvil publicada, sistema interno de gestión y plataforma de punto de venta e inventario para librería.',
    tech: ['Flutter', 'Dart', 'GetX', 'Clean Architecture', 'Laravel', 'PHP', 'CodeIgniter', 'SQL'],
    category: 'mobile',
    links: [
      {
        label: 'Google Play',
        url: 'https://play.google.com/store/apps/details?id=com.campustd.pandevidarenovado&hl=es_MX',
        icon: 'play',
      },
      {
        label: 'App Store',
        url: 'https://apps.apple.com/us/app/pan-de-vida-renovado/id6741119703?l=es-MX',
        icon: 'apple',
      },
    ],
    highlights: [
      'App reconstruida desde cero',
      'Clean Architecture + GetX',
      'POS e inventario con Laravel',
      'Optimización y rutas en CodeIgniter',
    ],
    metrics: [
      { value: '2,572', label: 'sesiones iOS' },
      { value: '85', label: 'descargas iOS' },
      { value: '313', label: 'usuarios diarios Android aprox.' },
      { value: '307', label: 'actualizaciones iOS' },
    ],
    featured: true,
    accentColor: '#60725a',
    screenshots: [
      { src: '/projects/pandevida/eventos.webp', label: 'App — Eventos y Videos' },
      { src: '/projects/pandevida/pos.webp', label: 'App — Escaneo POS' },
      { src: '/projects/pandevida/menu.webp', label: 'App — Menú de Navegación' },
      { src: '/projects/pandevida/admin_dashboard.webp', label: 'Laravel — Dashboard Administrativo' },
      { src: '/projects/pandevida/admin_movimientos.webp', label: 'Laravel — Historial de Movimientos' },
      { src: '/projects/pandevida/admin_envios.webp', label: 'Laravel — Control de Envíos' },
      { src: '/projects/pandevida/ci_tests_ministerio.webp', label: 'CodeIgniter — Tests de Ministerios' },
      { src: '/projects/pandevida/ci_reportes_cumbres.webp', label: 'CodeIgniter — Reporte de Cumbres' },
    ],
  },
  {
    name: 'Petrotekno Control Interno',
    type: 'Plataforma Administrativa',
    description:
      'Plataforma para gestión de flota vehicular, asignación de proyectos y control de datos operativos.',
    tech: ['Laravel', 'PHP', 'SQL'],
    category: 'web',
    links: [
      { label: 'GitHub', url: 'https://github.com/analaradev/client-petrotekno-control_interno' },
    ],
    highlights: ['Módulos de registro y consulta', 'Control de flota y proyectos', 'Sistema en producción'],
    accentColor: '#879b80',
    screenshots: [
      { src: '/projects/petrotekno/dashboard.webp', label: 'Dashboard de Activos' },
      { src: '/projects/petrotekno/reportes.webp', label: 'Generación de Reportes' },
      { src: '/projects/petrotekno/configuracion.webp', label: 'Configuración de Catálogos' },
    ],
  },
  {
    name: 'Urban Arquitectura',
    type: 'Sitio Web Corporativo',
    description:
      'Rediseño y mejora de sitio web corporativo para presencia digital de firma de arquitectura.',
    tech: ['Astro', 'HTML', 'CSS', 'JavaScript'],
    category: 'web',
    links: [
      { label: 'Sitio Web', url: 'https://urbanarquitectura.mx/' },
      { label: 'GitHub', url: 'https://github.com/analaradev/client-urbanarquitectura-web' },
    ],
    highlights: ['Rediseño completo', 'Diseño responsivo', 'Identidad visual profesional'],
    accentColor: '#a5b8a0',
    screenshots: [
      { src: '/projects/urbanarquitectura/inicio.webp', label: 'Página de Inicio / Carrusel' },
      { src: '/projects/urbanarquitectura/talleres.webp', label: 'Talleres y Servicios Especializados' },
      { src: '/projects/urbanarquitectura/contacto.webp', label: 'Contacto y Ubicación' },
    ],
  },
  {
    name: 'Vida Saludable',
    type: 'Sistema Flutter',
    description:
      'Sistema para control de formularios y generación de reportes sanitarios escolares.',
    tech: ['Flutter', 'Dart', 'Firebase'],
    category: 'mobile',
    links: [
      { label: 'GitHub', url: 'https://github.com/analaradev/client-vida_saludable' },
    ],
    highlights: ['Formularios dinámicos', 'Reportes sanitarios', 'Gestión de datos con Firebase'],
    accentColor: '#6d8569',
    screenshots: [
      { src: '/projects/vidasaludable/dashboard.webp', label: 'Dashboard — Estadísticas y Gráficas' },
      { src: '/projects/vidasaludable/busqueda.webp', label: 'Búsqueda — Filtros y Alumnos' },
      { src: '/projects/vidasaludable/detalle.webp', label: 'Detalle — Información y Evaluación' },
    ],
  },
  {
    name: 'Impacta Control de Activos',
    type: 'Sistema Web ERP',
    description:
      'Aplicación para la administración de activos, inventarios y flujos internos de recursos humanos en la empresa.',
    tech: ['Angular', '.NET Core', 'C#', 'SQL Server', 'GitHub'],
    category: 'web',
    links: [
      { label: 'GitHub', url: 'https://github.com/analaradev/proyecto_activos' }
    ],
    highlights: [
      'Frontend reactivo con Angular',
      'Backend robusto en .NET Core / C#',
      'Flujos de consulta y auditoría'
    ],
    accentColor: '#60725a'
  },
  {
    name: 'Revista Chavira',
    type: 'Catálogo Editorial Web',
    description:
      'Plataforma digital para la publicación y visualización del catálogo editorial y revista comercial de Grupo Chavira.',
    tech: ['HTML', 'CSS', 'JavaScript'],
    category: 'web',
    links: [
      { label: 'GitHub', url: 'https://github.com/analaradev/client-chavira-revista' }
    ],
    highlights: [
      'Visualización fluida de revista',
      'Diseño moderno y responsivo',
      'Navegación sencilla sin dependencias'
    ],
    accentColor: '#879b80'
  },
  {
    name: 'Gestión Taller Mecánico',
    type: 'Prototipo Mobile',
    description:
      'Prototipo móvil para el control de inventario de repuestos y asignación de órdenes de servicio en talleres automotrices.',
    tech: ['Flutter', 'Dart'],
    category: 'mobile',
    links: [
      { label: 'GitHub', url: 'https://github.com/analaradev/lab-mecanico' }
    ],
    highlights: [
      'Flujo de órdenes de servicio',
      'Gestión de piezas y refacciones',
      'Arquitectura modular limpia'
    ],
    accentColor: '#a5b8a0'
  }
];

function getLinkIcon(label: string, icon?: string): string {
  if (icon === 'play') {
    return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
  }
  if (icon === 'apple') {
    return `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>`;
  }
  if (label === 'GitHub') {
    return `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`;
  }
  if (label === 'Sitio Web') {
    return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`;
  }
  return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`;
}
---

<Layout title="Todos los Proyectos | Ana Patricia Hernández Lara">
  <Navbar />
  
  <main class="projects-page">
    <div class="container">
      <!-- Back to Home -->
      <div class="back-home-wrapper animate-in visible">
        <a href="/" class="btn-back-home">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Volver al inicio
        </a>
      </div>

      <!-- Header -->
      <h1 class="page-title gradient-text animate-in visible">Proyectos & Prototipos</h1>
      <p class="page-subtitle animate-in visible">Catálogo completo de mis desarrollos web, aplicaciones móviles y soluciones de software.</p>

      <!-- Filter bar -->
      <div class="filter-bar animate-in visible">
        <button class="filter-btn active" data-filter="all">Todos</button>
        <button class="filter-btn" data-filter="mobile">Mobile (Flutter)</button>
        <button class="filter-btn" data-filter="web">Web & Backend</button>
        <button class="filter-btn" data-filter="others">Otros</button>
      </div>

      <!-- Projects Grid -->
      <div class="projects-grid" id="projects-grid">
        {projects.map((project) => (
          <article
            class="project-card glass-card animate-in visible"
            data-category={project.category}
            style={`--card-accent: ${project.accentColor};`}
          >
            <div class="project-card__glow" />

            <div class="project-card__content">
              <div class="project-card__header">
                <span class="project-card__type">{project.type}</span>
              </div>

              <h3 class="project-card__title">{project.name}</h3>
              <p class="project-card__description">{project.description}</p>

              <div class="project-card__details">
                <ul class="project-card__highlights">
                  {project.highlights.map((h) => (
                    <li class="project-card__highlight">
                      <svg class="project-card__check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      {h}
                    </li>
                  ))}
                </ul>

                {project.metrics && project.metrics.length > 0 && (
                  <div class="project-card__metrics" aria-label={`Métricas de ${project.name}`}>
                    {project.metrics.map((metric) => (
                      <div class="project-card__metric">
                        <strong>{metric.value}</strong>
                        <span>{metric.label}</span>
                      </div>
                    ))}
                  </div>
                )}

                <div class="project-card__tech-links">
                  <div class="project-card__tech">
                    {project.tech.map((t) => (
                      <span class="project-card__tech-tag">{t}</span>
                    ))}
                  </div>

                  {project.links.length > 0 && (
                    <div class="project-card__links">
                      {project.links.map((link) => (
                        <a
                          href={link.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="project-card__link"
                        >
                          <Fragment set:html={getLinkIcon(link.label, link.icon)} />
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>

            {project.screenshots && project.screenshots.length > 0 && (
              <div class="project-card__gallery">
                <div class="project-card__gallery-viewport">
                  {project.screenshots.map((shot, idx) => (
                    <img
                      src={shot.src}
                      alt={shot.label}
                      class={`project-card__gallery-img ${idx === 0 ? 'active' : ''}`}
                      data-index={idx}
                    />
                  ))}
                </div>
                <div class="project-card__gallery-caption">
                  <span class="project-card__gallery-label">{project.screenshots[0].label}</span>
                  <span class="project-card__gallery-counter">1 / {project.screenshots.length}</span>
                </div>
                {project.screenshots.length > 1 && (
                  <div class="project-card__gallery-controls">
                    <button class="project-card__gallery-btn prev-btn" aria-label="Anterior">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button class="project-card__gallery-btn next-btn" aria-label="Siguiente">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                  </div>
                )}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </main>

  <!-- Lightbox Modal Dialog -->
  <dialog id="project-lightbox" class="lightbox-dialog" aria-modal="true" aria-label="Visualizador de imágenes">
    <div class="lightbox-container">
      <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar visualizador">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      
      <div class="lightbox-content">
        <button class="lightbox-nav-btn prev-btn" id="lightbox-prev" aria-label="Imagen anterior">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        
        <div class="lightbox-image-wrapper" id="lightbox-wrapper">
          <img id="lightbox-img" class="lightbox-img" src="" alt="" />
        </div>
        
        <button class="lightbox-nav-btn next-btn" id="lightbox-next" aria-label="Siguiente imagen">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
      
      <div class="lightbox-caption">
        <p id="lightbox-label" class="lightbox-label"></p>
        <span id="lightbox-counter" class="lightbox-counter"></span>
      </div>
    </div>
  </dialog>
</Layout>

<style>
  .projects-page {
    padding: 8rem 0 6rem;
    background: linear-gradient(
      180deg,
      var(--bg-primary) 0%,
      var(--bg-secondary) 50%,
      var(--bg-primary) 100%
    );
    min-height: 100vh;
  }

  .back-home-wrapper {
    margin-bottom: 2rem;
  }

  .btn-back-home {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    transition: var(--transition);
  }

  .btn-back-home:hover {
    color: var(--accent-primary);
    transform: translateX(-4px);
  }

  .page-title {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 700px;
    margin-bottom: 3rem;
  }

  /* ── Filter Bar ──────────────────────────────────────── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    padding: 0.6rem 1.35rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid var(--glass-border);
    background: var(--glass);
    color: var(--text-secondary);
    cursor: pointer;
    transition: var(--transition);
  }

  .filter-btn:hover {
    transform: translateY(-1px);
    background: rgba(96, 114, 90, 0.08);
    border-color: rgba(96, 114, 90, 0.25);
    color: var(--text-primary);
  }

  .filter-btn.active {
    background: var(--accent-primary);
    border-color: var(--accent-primary);
    color: #ffffff;
    box-shadow: 0 4px 15px rgba(96, 114, 90, 0.22);
  }

  /* ── Projects Grid ───────────────────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2rem;
  }

  /* ── Card Styling ────────────────────────────────────── */
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.4s ease,
      opacity 0.4s ease;
  }

  /* Filter transition states */
  .project-card.hidden {
    display: none;
    opacity: 0;
    transform: scale(0.95);
  }

  .project-card__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--card-accent),
      transparent
    );
    opacity: 0.25;
  }

  .project-card__glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--card-accent) 8%, transparent),
      transparent 70%
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .project-card:hover {
    transform: translateY(-6px);
    box-shadow:
      0 20px 40px rgba(96, 114, 90, 0.08),
      0 0 30px color-mix(in srgb, var(--card-accent) 12%, transparent);
    border-color: var(--card-accent);
  }

  .project-card:hover .project-card__glow {
    opacity: 1;
  }

  .project-card:hover .project-card__title {
    color: var(--card-accent);
  }

  .project-card__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-card__type {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.85rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-accent) 25%, transparent);
  }

  .project-card__title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .project-card__description {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .project-card__highlights {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0.25rem 0;
  }

  .project-card__highlight {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .project-card__check {
    flex-shrink: 0;
    color: var(--card-accent);
    opacity: 0.85;
  }

  .project-card__metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .project-card__metric {
    padding: 0.75rem 0.85rem;
    border-radius: var(--border-radius-sm);
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--glass-border);
    transition: var(--transition);
  }

  .project-card:hover .project-card__metric {
    border-color: color-mix(in srgb, var(--card-accent) 28%, transparent);
  }

  .project-card__metric strong {
    display: block;
    color: var(--card-accent);
    font-family: var(--font-mono);
    font-size: 1.05rem;
    line-height: 1.1;
    margin-bottom: 0.25rem;
  }

  .project-card__metric span {
    display: block;
    color: var(--text-secondary);
    font-size: 0.72rem;
    line-height: 1.25;
  }

  .project-card__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
    padding-top: 0.5rem;
