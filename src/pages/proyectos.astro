    overflow: hidden;
    background: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-in;
  }

  .project-card__gallery-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.5rem;
    opacity: 0;
    transition: opacity 0.35s ease, transform 0.35s ease;
    transform: scale(0.97);
